# Supabase — from Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Email — from resend.com dashboard
RESEND_API_KEY=re_...
# Use onboarding@resend.dev (Resend shared domain) for dev/demo — no domain verification needed.
# Emails will only deliver to your own Resend-verified address in sandbox mode.
# For production, set this to noreply@yourdomain.com after verifying the domain in Resend.
EMAIL_FROM=onboarding@resend.dev

# Google Cloud — from GCP console
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}
GEMINI_API_KEY=AIza...
GOOGLE_API_KEY=AIza...
GOOGLE_SEARCH_ENGINE_ID=...

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
ENABLE_REAL_CRAWLER=false
ENABLE_SOCIAL_SCAN=false

# SauceNAO reverse image search — free API key at saucenao.com/user.php?page=login
# Without a key, requests are rate-limited to ~6/day. With free key: 100/day.
SAUCENAO_API_KEY=
